# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=signreader
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=signreader_db
DATABASE_URL=postgresql://signreader:CHANGE_ME_strong_password@postgres:5432/signreader_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Application ──────────────────────────────────────────────────────────────
# python3 -c "import secrets; print(secrets.token_hex(32))" で生成
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
API_DEBUG=false

# ─── OCR ──────────────────────────────────────────────────────────────────────
OCR_MIN_CONFIDENCE=0.81
USE_GOOGLE_VISION=false
GOOGLE_VISION_THRESHOLD=0.85
# USE_GOOGLE_VISION=true の場合は以下も設定
# GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-credentials.json
