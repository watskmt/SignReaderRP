# ─────────────────────────────────────────────────────────────────────────────
# SignReader Backend — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://signreader:CHANGE_ME@localhost:5432/signreader_db

# Redis connection string used by the cache service.
# Format: redis://<host>:<port>/<db_number>
REDIS_URL=redis://localhost:6379/0

# Set to true to enable FastAPI debug mode (auto-reload, detailed tracebacks).
# MUST be false in production.
API_DEBUG=false

# Secret key used for signing tokens. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# MUST be rotated before deploying to production.
SECRET_KEY=CHANGE_ME_generate_a_secure_random_key

# Set to true to use Google Cloud Vision API instead of PaddleOCR.
# Requires GOOGLE_APPLICATION_CREDENTIALS to be set in the environment.
USE_GOOGLE_VISION=false

# Minimum confidence threshold (0–1) for Google Vision results.
# Results below this value will be discarded.
GOOGLE_VISION_THRESHOLD=0.85

# Minimum confidence threshold (0–1) for PaddleOCR results.
# Increase to reduce false positives; decrease to capture more text.
OCR_MIN_CONFIDENCE=0.6

# Redis URL for Celery task broker (use a separate DB index from cache).
CELERY_BROKER_URL=redis://localhost:6379/1

# Redis URL for Celery result backend (use a separate DB index from broker).
CELERY_RESULT_BACKEND=redis://localhost:6379/2
